{
  "detachments": [
    {
      "id": "am_tempestus_boarding_regiment",
      "name": "Tempestus Boarding Regiment",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Purge-Sweep Protocols",
        "desc": "Each time a MILITARUM TEMPESTUS unit from your army is selected to shoot, if one or more models from that unit are within 1\" of an open Hatchway and every model in that unit is on the same side of that Hatchway, select one enemy unit on the opposite side of that Hatchway from the unit. Until the end of the phase, ranged weapons equipped by models in that unit have the [LETHAL HITS] ability while targeting that enemy unit. Tempestus Scion units can perform the Secure Site Tactical Manoeuvre as if they had the BATTLELINE keyword."
      },
      "enhancements": [
        {
          "id": "enh_am_covert_breach",
          "name": "Covert Breach",
          "desc": "At the start of the first battle round, the bearer's unit may make a Normal move of up to 6\".",
          "requiresKeywords": []
        },
        {
          "id": "enh_am_elimination_force",
          "name": "Elimination Force",
          "desc": "At the start of the first battle round, select one enemy unit. Each time a model in the bearer's unit makes an attack that targets that enemy unit, if the Strength characteristic of the attack is less than the Toughness characteristic of that enemy unit, add 1 to the Wound roll.",
          "requiresKeywords": []
        }
      ],
      "exclusiveUnitGroups": [
        [
          "am_commissar",
          "am_ministorum_priest",
          "am_ogryn_bodyguard",
          "am_primaris_psyker",
          "am_tech_priest_enginseer"
        ]
      ],
