    {
      "id": "am_embarked_regiment",
      "name": "Embarked Regiment",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Get Down!",
        "desc": "Each time an ASTRA MILITARUM unit from your army is selected to shoot, you can select one other friendly ASTRA MILITARUM unit (excluding OGRYN units). Until the end of the phase, models in the attacking unit can ignore models in the friendly unit for the purposes of determining visibility."
      },
      "enhancements": [
        {
          "id": "enh_am_er_rigged_blind_grenades",
          "name": "Rigged Blind Grenades",
          "desc": "Once per battle, when an enemy unit opens a Hatchway, if the bearer is on the battlefield, it can use this Enhancement. If it does, roll one D6: on a 2+, that enemy unit is Battle-shocked.",
          "requiresKeywords": []
        },
        {
          "id": "enh_am_er_shipboard_veteran",
          "name": "Shipboard Veteran",
          "desc": "Each time you target an ASTRA MILITARUM unit from your army with a Strategem, if that unit is visible to the bearer, roll one D6: on a 4+, you gain 1CP.",
          "requiresKeywords": []
        }
      ],
