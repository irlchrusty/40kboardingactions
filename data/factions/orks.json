{
  "detachments": [
    {
      "id": "orks_kaptin_killers",
      "name": "Kaptin Killers",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Comin' Through",
        "desc": "In your Movement phase, Desperate Escape tests taken for ORKS models in your army are automatically passed, and each time an ORKS unit from your army makes a Normal, Advance or Fall Back move, it can move through other units as if they were not there, provided those models have a lower Toughness characteristic than it."
      },
      "enhancements": [
        {
          "id": "enh_orks_tellyporta",
          "name": "Tellyporta",
          "desc": "In the Deploy Armies step, select one Meganobz unit from your army. Until the end of the battle, models in that unit have the Deep Strike ability.",
          "requiresKeywords": []
        },
        {
          "id": "enh_orks_gnasher_squig_crates",
          "name": "Gnasher Squig Crates",
          "desc": "WARBOSS model only. In your Command phase, you can select one Nobz or Meganobz unit from your army (excluding Battle-shocked units) that is within 6\" of the bearer and is within range of an objective marker. If there is no enemy units within range of that objective marker, it is Secured by your army.",
          "requiresKeywords": [
            "WARBOSS"
          ]
        }
      ],
