    {
      "id": "orks_ramship_raiders",
      "name": "Ramship Raiders",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Belligerent Boarders",
        "desc": "Each time an attack targets an ORKS unit from your army (excluding GROT units), if the Strength characteristic of the attack is greater than the Toughness characteristic of that Orks unit, subtract 1 from the Wound roll."
      },
      "enhancements": [
        {
          "id": "enh_orks_living_battering_ram",
          "name": "Living Battering Ram",
          "desc": "Each time the bearer tries to operate a closed Hatchway, your opponent cannot try to prevent it. In addition, each time the bearer opens a Hatchway, each enemy unit within 6\" of that Hatchway and wholly on the opposite side of it from the bearer must take a Battle-shock test.",
          "requiresKeywords": []
        },
        {
          "id": "enh_orks_scarred_brute",
          "name": "Scarred Brute",
          "desc": "The bearer has the Feel No Pain 5+ ability.",
          "requiresKeywords": []
        }
      ],
