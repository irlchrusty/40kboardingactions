    {
      "id": "dg_vectors_of_decay",
      "name": "Vectors of Decay",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Sevenfold Offerings",
        "desc": "For every seven enemy models that have been destroyed, add 2\" to the Contagion Range of units from your army. Note that any increase to the Contagion Range of units from your army as a result of this rule does not take place while a unit from your army is attacking. In such an event, the increase will take place after such a unit has finished making its attacks."
      },
      "enhancements": [
        {
          "id": "enh_dg_foul_constitution",
          "name": "Foul Constitution",
          "desc": "Each time an attack is allocated to the bearer, subtract 1 from the Damage characteristic of the attack.",
          "requiresKeywords": []
        },
        {
          "id": "enh_dg_fountaining_filth",
          "name": "Fountaining Filth",
          "desc": "When the bearer is destroyed, before removing it from the battlefield, select one enemy unit within engagement range of the bearer and roll one D6: On a 2-3, that enemy unit suffers one mortal wound, on a 4-5, that enemy unit suffers two mortal wounds, on a 6, that enemy unit suffers 3 mortal wounds.",
          "requiresKeywords": []
        }
      ],
