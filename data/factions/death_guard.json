{
  "detachments": [
    {
      "id": "dg_arch_contaminators",
      "name": "Arch-Contaminators",
      "specialRule": {
        "name": "Inescapable Corruption",
        "desc": "Each time an enemy unit is selected to perform a Tactical Manoeuvre, if that unit is within Contagion Range of one or more units from your army, that enemy unit must take a Leadership test. If that test is failed, that Tactical Manoeuvre has no effect (that enemy unit is still eligible to shoot and declare a charge this turn as normal). In addition, in your Command Phase, roll one D6 for each objective marker that is within Contagion Range of one or more units from your army and is Secured by your opponents army: on a 5+, that objective is no longer secured. Blightlord Terminator units may perform the Secure Site Tactical Manoeuvre as if they had the BATTLELINE keyword."
      },
      "enhancements": [
        {
          "id": "enh_dg_miasmic_odour",
          "name": "Miasmic Odour",
          "desc": "Add 3\" to the Contagion Range of the bearer.",
          "requiresKeywords": []
        },
        {
          "id": "enh_dg_disgusting_reinvigoration",
          "name": "Disgusting Reinvigoration",
          "desc": "Each time the bearer destroys an enemy model with a melee attack, roll one D6: on a 5+, the bearer regains one lost wound (to a maximum of two wounds per phase).",
          "requiresKeywords": []
        }
      ],
      "units": [
        {
          "id": "dg_typhus",
          "max": 1
        },
        {
          "id": "dg_lord_of_contagion",
          "max": 1
        },
        {
          "id": "dg_lord_of_virulence",
          "max": 1
        },
        {
          "id": "dg_blightlord_terminators",
          "max": 1
        },
        {
          "id": "dg_deathshroud_terminators",
          "max": 1
        },
        {
          "id": "dg_chaos_spawn",
          "max": 1
        }
      ],
      "maxCharacters": 2
    },
    {
      "id": "dg_unclean_uprising",
      "name": "Unclean Uprising",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Relentless Spread",
        "desc": "Each time a DEATH GUARD unit from your army makes a Consolidation move, it can move up to D3 + 3\" instead of up to 3\". If it cannot end that move within Engagement Range of one or more enemy units that are visible to it (and in Unit Coherency), it can still make that move, and when doing so can move in any direction."
      },
      "enhancements": [
        {
          "id": "enh_dg_pox_bearer",
          "name": "Pox-Bearer",
          "desc": "Once per battle, at the end of your Movement phase, the bearer can use this Enhancement. If it does, select one friendly Poxwalkers units within 9\" and visible to the bearer, return up to D3+2 destroyed models to that unit.",
          "requiresKeywords": []
        },
        {
          "id": "enh_dg_hand_of_nurgle",
          "name": "Hand of Nurgle",
          "desc": "In your Command phase, select one objective marker that you control and is within range of the bearer. Roll a D6: on a 2+ that objective marker is Secured by your army.",
          "requiresKeywords": []
        }
      ],
