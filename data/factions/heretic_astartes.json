      "id": "csm_infernal_reavers",
      "name": "Infernal Reavers",
      "specialRule": {
        "name": "Dark Rewards",
        "desc": "Each time a HERETIC ASTARTES model from your army takes a Leadership test for the Dark Pacts ability, on a 9+, you gain 1 CP."
      },
      "enhancements": [
        {
          "id": "enh_csm_voice_of_the_octed",
          "name": "Voice of the Octed",
          "desc": "Each time the bearer's unit makes a Dark Pact, until the end of the Phase, weapons equipped by models in that unit gain both abilities conferred by that Dark Pact (instead of only one).",
          "requiresKeywords": []
        },
        {
          "id": "enh_csm_swollen_with_power",
          "name": "Swollen with Power",
          "desc": "Add 1 to the bearers Toughness characteristic. Each time the bearer's unit attempts to operate a Hatchway that an enemy unit is trying to prevent, and each time the bearer's unit tries to prevent an enemy unit from operating a Hatchway, in the resulting roll off, you can re-roll your result.",
          "requiresKeywords": []
        }
      ],
