{
  "detachments": [
    {
      "id": "adm_response_clade",
      "name": "Response Clade",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Procedural Elimination",
        "desc": "At the start of the battle round, select either melee attacks or ranged attacks. Until the end of the battle round, each time a SKITARII model from your army makes an attack of the select type, re-roll a Hit roll of 1."
      },
      "enhancements": [
        {
          "id": "enh_adm_admonissor_shunt",
          "name": "Admonissor Shunt",
          "desc": "Once per battle, at the start of any phase, if the bearer is on the battlefield, you can select one friendly SKITARII unit that is Battle-shocked. That unit is no longer Battle-shocked.",
          "requiresKeywords": []
        },
        {
          "id": "enh_adm_optimised_cogitators",
          "name": "Optimised Cogitators",
          "desc": "Once per battle round when you target the bearer with a Stratagem, that use of the Stratagem costs 1 less CP than normal.",
          "requiresKeywords": []
        }
      ],
      "units": [
        {
          "id": "adm_skitarii_marshall",
          "max": 2
        },
        {
          "id": "adm_skitarii_rangers",
          "max": 3
        },
        {
          "id": "adm_skitarii_vanguard",
