    {
      "id": "adm_electromartyrs",
      "name": "Electromartyrs",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Overload Machine Spirits",
        "desc": "Each time an ADEPTUS MECHANICUS unit from your army is select to shoot, it can use this ability. If it does, until the end of the phase, improve the Armour Penetration characteristic of ranged weapons equipped by models in that unit by 1 and those weapons have the [HAZARDOUS] ability."
      },
      "enhancements": [
        {
          "id": "enh_adm_remote_lockdown",
          "name": "Remote Lockdown",
          "desc": "Once per battle round when an enemy unit attempts to operate a Hatchway, if that Hatchway is within 9\" and visible to the bearer, it can use this Enhancement. If it does, it can attempt to prevent that unit from operating that Hatchway as if the bearer was within 1\" of that Hatchway.",
          "requiresKeywords": []
        },
        {
          "id": "enh_adm_multi_dimensional_auspex",
          "name": "Multi-Dimensional Auspex",
          "desc": "Once per battle, in your Shooting phase, when the bearer is selected to shoot, it can use this Enhancement. If it does, until the end of the phase, it can ignore Walls and closed Hatchways for the purposes of determining visibility and the Range characteristic of the ranged weapons it is equipped with is changed to 6\".",
          "requiresKeywords": []
        }
      ],
