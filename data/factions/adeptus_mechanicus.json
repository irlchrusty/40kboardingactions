          "max": 1
        }
      ]
    },
    {
      "id": "adm_machine_cult",
      "name": "Machine Cult",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Canticles of the Omnissiah",
        "desc": "Add 1 to Advance rolls, Charge rolls and Battle-shock tests taken for TECH-PRIEST and ELECTRO-PRIESTS units in your army. ELECTRO-PRIESTS can perform the Secure Sites Tactical Manoeuvre as if they had the BATTLELINE keyword."
      },
      "enhancements": [
        {
          "id": "enh_adm_beseech_the_machine_spirits",
          "name": "Beseech the Machine Spirits",
          "desc": "At the end of the Move Units step of your Movement phase, the bearer can attempt to operte a Hatchway that is visible to and within 9\" of it, instead of within 1\". When doing so, if your opponent attempts to prevent it, add the bearer's Toughness characteristic to your result of the roll-off, instead of that of a friendly model within 1\" of that Hatchway.",
          "requiresKeywords": []
        },
        {
          "id": "enh_adm_harmonic_discordator",
          "name": "Harmonic Discordator",
          "desc": "In the Battle-shock step of your opponents Command Phase, if an enemy unit that is below it's Starting Strength is within 3\" of the bearer, that unit must take a Battle-shock test. If that enemy unit is also Below Half-Strength, subtract 1 from that test. This Enhancement cannot cause a unit to take two Battle-shock tests in the same phase.",
          "requiresKeywords": []
        }
      ],
