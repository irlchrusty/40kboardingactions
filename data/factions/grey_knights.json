    {
      "id": "gk_void_purge_force",
      "name": "Void Purge Force",
      "maxCharacters": 2,
      "specialRule": {
        "name": "An Urgent Duty",
        "desc": "Add 1 to Advance and Charge rolls made for GREY KNIGHTS units in your army."
      },
      "enhancements": [
        {
          "id": "enh_gk_sigil_of_warding",
          "name": "Sigil of Warding",
          "desc": "Once per battle, at the end of your Shooting phase, the bearer can use this enhancement. If it does, it can make a Normal move of up to 3\" and can then attempt to operate a Hatchway. The bearer is then not eligible to declare a charge this turn.",
          "requiresKeywords": []
        },
        {
          "id": "enh_gk_tactical_haruspexy",
          "name": "Tactical Haruspexy",
          "desc": "Once per battle, when the bearer declares a charge, it can use this Enhancement. If it does, it can select units that are not visible to it as targets of that charge, provided they are within 9\" of it.",
          "requiresKeywords": []
        }
      ],
