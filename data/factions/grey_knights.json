{
  "detachments": [
    {
      "id": "gk_baneslayer_strike",
      "name": "Baneslayer Strike",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Pre-Emptive Strike",
        "desc": "In the Reinforcement step of your first Movement phase, you can set up on the battlefield one GREY KNIGHTS unit from your army using the Deep Strike ability. When doing so, you can set up this unit anywhere on the battlefield that is more than 6\" horizontally away from all enemy models (measure this distance as you would normally for the Deep Strike ability). Until the end of the turn, that unit is not eligible to declare a charge."
      },
      "enhancements": [
        {
          "id": "enh_gk_shield_of_admonishment",
          "name": "Shield of Admonishment",
          "desc": "Each time a melee attack targets the bearer, subtract 1 from the Hit roll.",
          "requiresKeywords": []
        },
        {
          "id": "enh_gk_close_and_sanction",
          "name": "Close and Sanction",
          "desc": "In your opponents Shooting phase, each time an enemy unit is selected to shoot, after that unit has shot, if the bearer was hit by one of more of those attacks, the bearer can make a Dash move. To do so, roll one D6: the bearer can be moved a distance in inches up to the result, but it must finish that move as close as possible to the nearest visible enemy unit. When doing so, it can be moved within Engagement Range of that enemy unit. The bearer can only make one Dash move per phase.",
          "requiresKeywords": []
        }
      ],
