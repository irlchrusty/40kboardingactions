      "id": "sor_penitents_and_pilgrims",
      "name": "Penitents and Pilgrims",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Bloody Redemption",
        "desc": "The first time that you gain a Miracle dice as the result of an Arco-Flagellants or Repentia Squad unit from your army being destroyed, do not roll a D6; that Miracle dice has a value of 6 instead."
      },
      "enhancements": [
        {
          "id": "enh_sor_fervent_ferocity",
          "name": "Fervent Ferocity",
          "desc": "The bearer has the Feel No Pain 5+ ability.",
          "requiresKeywords": []
        },
        {
          "id": "enh_sor_sanctification_rituals",
          "name": "Sanctification Rituals",
          "desc": "The bearer can perform the Secure Site Tactical Manoeuvre as if it has the BATTLELINE keyword.",
          "requiresKeywords": []
        }
      ],
