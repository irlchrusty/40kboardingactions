      "id": "ld_pandaemoniac_inferno",
      "name": "Pandaemoniac Inferno",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Living Flame",
        "desc": "Each time a TZEENTCH LEGIONES DAEMONICA unit from your army is selected to shoot, it can target enemy models within Engagement Range of other friendly TZEENTCH LEGIONES DAEMONICA units. Ranged weapons equipped by TZEENTCH LEGIONES DAEMONICA models have the [SUSTAINED HITS 1] ability while targeting a unit within Engagement Range of one or more friendly models."
      },
      "enhancements": [
        {
          "id": "enh_ld_fulgurating_presence",
          "name": "Fulgurating Presence",
          "desc": "Each time an attack targets the bearer, subtract 1 from the Hit roll.",
          "requiresKeywords": []
        },
        {
          "id": "enh_ld_mutagenic_flames",
          "name": "Mutagenic Flames",
          "desc": "In your Shooting phase, after the bearer has shot, select one enemy unit hit by one or more of those attacks. Until the start of your next Shooting phase, each time a model in that unit makes an attack, subtract 1 from the Hit roll.",
          "requiresKeywords": []
        }
      ],
