{
  "detachments": [
    {
      "id": "ld_rotten_and_rusted",
      "name": "Rotten and Rusted",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Toxic Miasma",
        "desc": "While an enemy unit is within 3\" of one or more NURGLE LEGIONES DAEMONICA units from your army, halve the Move characteristic of models in that unit and subtract 1 from Advance and Charge rolls made for it. When measuring this distance, Walls and closed Hatchways are ignored."
      },
      "enhancements": [
        {
          "id": "enh_ld_virulent_corruption",
          "name": "Virulent Corruption",
          "desc": "Each time an enemy unit within Engagement range of the bearer is selected to Fall Back, models in that unit must take Desperate Escape tests as if that unit was Battle-shocked. When doing so, if that unit is also Battle-shocked by other means, subtract 1 from each of those Desperate Escape tests.",
          "requiresKeywords": []
        },
        {
          "id": "enh_ld_endless_gift",
          "name": "Endless Gift",
          "desc": "Add 2 to the bearer's Wounds characteristic.",
          "requiresKeywords": []
        }
      ],
