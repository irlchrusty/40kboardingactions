    {
      "id": "aeldari_wraiths_of_the_void",
      "name": "Wraiths of the Void",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Wraith-Marked",
        "desc": "In your Command phase, you can select one AELDARI unit from your army within range of an objective marker you control. That unit must take a Leadership test, subtracting 2 from the result if it has the WRAITH CONSTRUCT keyword: if passed, that objective marker is Secured by your army."
      },
      "enhancements": [
        {
          "id": "enh_aeldari_direct_guidance",
          "name": "Direct Guidance",
          "desc": "At the end of your Movement phase, select one friendly WRAITH CONSTRUCT unit within 6\" of, and visible to the bearer. Until the end of the turn, that WRAITH CONSTRUCT unit is eligible to shoot and declare a charge in a turn in which it Fell Back.",
          "requiresKeywords": []
        },
        {
          "id": "enh_aeldari_song_of_renewal",
          "name": "Song of Renewal",
          "desc": "In your Command phase, the bearer can use this enhancement. If it does, select one friendly WRAITH CONSTRUCT unit within 6\" of, and visible to the bearer. Return one destroyed model to that WRAITH CONSTRUCT unit with its full wounds remaining. The bearer can only use this Enhancement up to two times.",
          "requiresKeywords": []
        }
      ],
      "units": [
        {
          "id": "aeldari_spiritseer",
          "max": 2
        },
        {
          "id": "aeldari_wraithblades",
          "max": 2
        },
        {
          "id": "aeldari_wraithguard",
          "max": 2
        }
      ]
    },
    {
      "id": "aeldari_khaines_arrow",
      "name": "Khaine's Arrow",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Unerring Strike",
        "desc": "In your Movement phase, each time an AELDARI unit from your army makes a Normal move, while making that move, it can attempt to operate a closed Hatchway that is within 1\" of it at any point during that move, provided that there are no enemy units within 1\" of that Hatchway. If that AELDARI unit does attempt to operate that Hatchway, reduce the distance each model in that unit can move by 2\" (if this makes it impossible for that unit to get within 1 of the Hatchway it wishes to operate, then it cannot attempt to do so), and it cannot operate a Hatchway again this turn."
      },
      "enhancements": [
        {
          "id": "enh_aeldari_ka_runes_of_sanctuary",
          "name": "Runes of Sanctuary",
          "desc": "PSYKER model only. Once per turn, in your opponent's Shooting phase, when a friendly AELDARI unit within 9\" of and visible to the bearer is selected as the target of a ranged attack, the bearer can use this Enhancement. If it does, until the end of the phase, each time an attack targets that friendly AELDARI unit, worsen the Armour Penetration characteristic of the attack by 1.",
          "requiresKeywords": ["PSYKER"]
        },
        {
          "id": "enh_aeldari_ka_shieldmaster",
          "name": "Shieldmaster",
          "desc": "Once per turn, in your Movement phase, after the bearer has moved, you can close one open Hatchway it moved through this phase (this can be done in addition to operating a Hatchway using the Unerring Strike Detachment rule).",
          "requiresKeywords": []
        }
      ],
