{
  "detachments": [
    {
      "id": "aeldari_star_dancer_masque",
      "name": "Star-Dancer Masque",
      "maxCharacters": 2,
      "specialRule": {
        "name": "Faolchu's Last Flight",
        "desc": "Each time an AELDARI model from your army is destroyed by a melee attack, if it has not fought this phase, roll one D6: on a 3+, do not remove it from play. The destroyed model can fight after the attacking model's unit has finished making its attacks, and is then removed from play."
      },
      "enhancements": [
        {
          "id": "enh_aeldari_prismatic_garb",
          "name": "Prismatic Garb",
          "desc": "Enemy units cannot fire Overwatch at the bearer.",
          "requiresKeywords": []
        },
        {
          "id": "enh_aeldari_path_of_eldanesh",
          "name": "Path of Eldanesh",
          "desc": "The bearer has the Fights First ability and, each time the bearer opens a Hatchway, until the end of the turn, improve the Armour Penetration characteristic of the melee weapons equipped by the bearer by 1.",
          "requiresKeywords": []
        }
      ],
